# ─── WooCommerce REST API ───────────────────────────────────────────────────
# Generate these from: WP Admin → WooCommerce → Settings → Advanced → REST API
WC_BASE_URL=https://nouvelespaceserigraphik.ma/wp-json/wc/v3
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Revalidation (webhook secret for ISR) ──────────────────────────────────
# Set this in WooCommerce webhook payload and match it here
REVALIDATE_SECRET=your_random_secret_here

# ─── Site Config ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nouvelespaceserigraphik.ma
NEXT_PUBLIC_WHATSAPP_NUMBER=212522448090
NEXT_PUBLIC_PHONE=+212-522-44-80-90
NEXT_PUBLIC_ADDRESS=Bd Mohammed V, Casablanca 20250
NEXT_PUBLIC_EMAIL=contact@nouvelespaceserigraphik.ma

# ─── Neon Database (leads CRM + admin settings) ─────────────────────────────
# Create a free project at https://neon.tech
# Copy the "Connection string" from your project dashboard
DATABASE_URL=postgres://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Run migrations after configuring:
#   psql $DATABASE_URL < supabase/migrations/20260502_neon_full_schema.sql
#   psql $DATABASE_URL < supabase/migrations/20260502_nes_lead_activity.sql

# ─── Admin Panel ─────────────────────────────────────────────────────────────
# Plain password for the /admin area. Store a strong random string.
ADMIN_PASSWORD=your_strong_password_here
ADMIN_COOKIE_SECRET=your_32_char_random_secret_here
